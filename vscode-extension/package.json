{
  "name": "ai-buddy-extension",
  "displayName": "AI Buddy",
  "description": "Prototype VS Code extension for the AI Programming Buddy",
  "version": "0.0.2",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:aiBuddy.suggestCode",
    "onCommand:aiBuddy.fixError",
    "onCommand:aiBuddy.runCode",
    "onCommand:aiBuddy.openChat"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aiBuddy.suggestCode",
        "title": "AI Buddy: Suggest Code"
      },
      {
        "command": "aiBuddy.fixError",
        "title": "AI Buddy: Fix Errors"
      },
      {
        "command": "aiBuddy.runCode",
        "title": "AI Buddy: Run Code (Avatar Debug)"
      },
      {
        "command": "aiBuddy.openChat",
        "title": "AI Buddy: Open Chat"
      }
    ]
  },
  "scripts": {
    "test": "vscode-test"
  },
  "dependencies": {
    "axios": "^1.15.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "typescript": "^5.2.2"
  }
}
